APP_ENV=dev
LOG_LEVEL=INFO

# OpenAI-compatible LLM gateway (base URL = the `/v1` root, not `/v1/chat/completions`)
VLLM_BASE_URL=https://your-gateway.example.com/v1
VLLM_API_KEY=sk-replace-me
VLLM_DEFAULT_MODEL=Qwen/Qwen3.5-397B-A17B

# Web search (optional — tool auto-disables if unset)
TAVILY_API_KEY=tvly-replace-me

# LangGraph checkpointer (ephemeral session/thread state).
# Optional in v1 — chat memory is rebuilt from MessageDB each turn.
# In docker-compose this is overridden to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=2592000

# App data DB. SQLite for v1; swap to postgresql+asyncpg://... for prod.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# fastapi-users JWT — generate a long random string for prod.
JWT_SECRET=CHANGE_ME_IN_PROD
JWT_LIFETIME_SECONDS=604800

# Slack — single platform bot via Socket Mode. Adapter stays off if either is unset.
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me
