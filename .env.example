# Copy to .env and fill in real values.
# docker compose reads this file via env_file; Postgres/Redis URLs are set in compose.

# --- Required ---

# OpenAI-compatible LLM gateway (base URL = the /v1 root)
VLLM_BASE_URL=https://your-gateway.example.com/v1
VLLM_API_KEY=sk-replace-me
VLLM_DEFAULT_MODEL=Qwen/Qwen3.5-397B-A17B

# Auth — generate a long random string for prod
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional ---

# Web search tool (auto-disables if unset)
# TAVILY_API_KEY=tvly-replace-me

# Slack bot (adapter stays off if either is unset)
# SLACK_BOT_TOKEN=xoxb-replace-me
# SLACK_APP_TOKEN=xapp-replace-me

# Host port for the web UI (default 80)
# PORT=80
